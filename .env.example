# Admin-Passwort für Zugriff auf geschützte Adressdaten
ADMIN_PASSWORD=IhrSicheresPasswort

# Session Secret für Express-Sessions
SESSION_SECRET=IhrSicheresSessionSecret

# Brevo (E-Mail-Versand)
BREVO_API_KEY=your-brevo-api-key
SMTP_FROM=your-email@example.com

